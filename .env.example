# Continuous Care Portal — Environment Variables
# Copy to .env and fill in real values. Never commit .env.

# LLM provider (Alibaba DashScope / Qwen — OpenAI-compatible endpoint)
DASHSCOPE_API_KEY=
# Default is the international host; for a mainland-China DashScope key set:
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Frontend URL (optional, added to CORS allowlist)
FRONTEND_URL=
