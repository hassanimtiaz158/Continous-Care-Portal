        {"test": "esr_crp", "label": "ESR/CRP", "critical_rule": null, "critical_note": null},
        {"test": "renal_function", "label": "Renal function", "critical_rule": null, "critical_note": "Overlap with Nephrology's lupus nephritis workup."},
