        {"test": "troponin_serial", "label": "Troponin (serial)", "critical_rule": "value > 0.04", "critical_note": "Diagnostic for myocardial injury; trend confirms infarction."},
        {"test": "ck_mb", "label": "CK-MB", "critical_rule": null, "critical_note": null},
        {"test": "lipid_panel", "label": "Lipid panel", "critical_rule": null, "critical_note": null},
