  "diagnoses": [
    {
      "id": "AORTIC_DISSECTION",
      "label": "Aortic dissection (suspected/confirmed)",
      "default_pathway": ["A", "C", "D"],
      "urgency": "stat",
      "labs": [
        {"test": "d_dimer", "label": "D-dimer", "critical_rule": "value > 500", "critical_note": "Elevated D-dimer supports dissection; does not rule it out if normal in high pre-test probability."},
        {"test": "troponin", "label": "Troponin (high-sensitivity)", "critical_rule": "value > 0.04", "critical_note": "May be elevated if dissection involves coronary ostia."},
        {"test": "cbc", "label": "CBC", "critical_rule": null, "critical_note": null},
        {"test": "type_and_crossmatch", "label": "Type & crossmatch", "critical_rule": null, "critical_note": "Required pre-operatively for CT Surgery."},
        {"test": "renal_function", "label": "Renal function (Cr/eGFR)", "critical_rule": "egfr < 30", "critical_note": "Contrast-nephropathy risk before CT angiography."}
      ],
      "imaging": [
        {"study": "ct_angiography", "label": "CT Angiography (chest/abdomen)", "urgency": "stat"}
      ],
      "consulting_departments": ["cardiothoracic_surgery", "radiology"]
    },
    {
      "id": "HOCM_SUSPECTED",
      "label": "Suspected hypertrophic obstructive cardiomyopathy",
      "default_pathway": ["B"],
